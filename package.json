{
  "name": "markdown-to-pdf-api",
  "version": "1.0.0",
  "description": "REST API that converts Markdown to PDF or HTML with multiple CSS themes",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit --testTimeout=15000"
  },
  "keywords": ["markdown", "pdf", "api", "converter"],
  "author": "Quesillo27",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "marked": "^9.1.6",
    "pdfkit": "^0.15.0",
    "dompurify": "^3.0.6",
    "jsdom": "^24.0.0",
    "highlight.js": "^11.9.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "nodemon": "^3.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  }
}
